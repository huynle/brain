# brain-api configuration
# Copy to .env and customize: cp .env.example .env

# === Brain Storage ===
BRAIN_DIR=~/.brain

# === Server ===
PORT=3333
HOST=0.0.0.0
LOG_LEVEL=info

# Optional: Default project ID
# DEFAULT_PROJECT=default

# === Authentication ===
# Enable API authentication (required for public deployment)
# ENABLE_AUTH=true

# API key for legacy auth (prefer token-based auth via `brain token create`)
# API_KEY=your-secret-api-key

# PIN for OAuth consent page (MCP client authorization)
# OAUTH_PIN=your-secure-pin

# === CORS ===
# Allowed origin for CORS (default: * allows all)
# For production, restrict to your domain:
# CORS_ORIGIN=https://brain.huynle.com

# === TLS ===
# Built-in TLS support (alternative to reverse proxy)
# ENABLE_TLS=true
# TLS_KEY=/path/to/privkey.pem
# TLS_CERT=/path/to/fullchain.pem

# === Multi-tenancy ===
# ENABLE_TENANTS=false
