# Brain API - Docker Deployment Configuration
# Copy to .env: cp .env.deploy.example .env
# Then run: just deploy

# === Domain (used by Traefik labels in docker-compose.yml) ===
# BRAIN_DOMAIN=brain.example.com

# === Authentication (enabled by default for deployment) ===
ENABLE_AUTH=true

# PIN for OAuth consent page (required for MCP client authorization)
# Uncomment and set a secure PIN:
# OAUTH_PIN=change-me-to-a-secure-pin

# === Server ===
PORT=3333
LOG_LEVEL=info

# === CORS ===
# Default allows all origins. For production, restrict to your domain:
# CORS_ORIGIN=https://brain.example.com

# === TLS ===
# Use if NOT behind a reverse proxy (Caddy/nginx/Traefik).
# If using a reverse proxy, leave these commented out.
# ENABLE_TLS=true
# TLS_KEY=/data/certs/privkey.pem
# TLS_CERT=/data/certs/fullchain.pem
